<style>
  
    .signup{
        display: inline-block;
        margin-top: 4rem;
        margin-bottom: 6rem;
        align-items: center;
        padding: 3rem 4rem;
        border-radius: 2rem;
        box-shadow: 1px 1px 20px 2px rgba(89, 89, 89, 0.5);
    }
    h1{
        font-size: 24px;
        color: #333333;
        margin-bottom: 10px;
        
    }
    .username,.password,.email{
        width: 100%;
        padding: 0.8rem 1rem; /* Padding for input fields */
        margin-bottom: 1rem; /* Space between fields */
        font-size: 1rem;
       
    }
    
    .btn-sign{
        background-color: #fe424d;
        color: #fff;
       
    }
    .btn-sign:hover{
        text-align: center;
        box-shadow: 1px 1px 20px 1px rgba(0, 0, 0, 0.5);
        font-weight: 700;
    }
  
</style>

<% layout("/layouts/boilerplate")%>
<div class="row mt-3">
    <div class="col-5 offset-3 signup">
        <div class="title"><h1>Sign Up for Wanderlust</h1></div>
        
        <form method="post" action="/signup" class="needs-validation" novalidate>
            <div class="mb-3 username">
            <label for="username" class="form-label " >Username</label>
            <input 
            name="username" 
            id="username"
            type="text" 
            class="form-control" 
            required
            >
            <div class="valid-feedback">Looks good</div>
            </div>

            <div class="mb-3 email">
                <label for="email" class="form-label " >Email</label>
                <input 
                name="email" 
                id="email"
                type="email" 
                class="form-control" 
                >
            </div>
            <div class="mb-3 password">
                <label for="password" class="form-label " >Password</label>
                <input 
                name="password" 
                id="password"
                type="password" 
                class="form-control" 
                >
            </div>
            <button class="btn btn-sign ">Sign Up</button>
        </form>
    </div>
</div> 